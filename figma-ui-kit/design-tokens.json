{
  "$schema": "https://tokens.studio/schemas/v1.json",
  "core": {
    "color": {
      "bg": { "$type": "color", "$value": "#080c14" },
      "surface-1": { "$type": "color", "$value": "#0d1220" },
      "surface-2": { "$type": "color", "$value": "#131a2e" },
      "surface-3": { "$type": "color", "$value": "#1a2238" },
      "border": { "$type": "color", "$value": "#1e2d45" },
      "text": { "$type": "color", "$value": "#cdd9f0" },
