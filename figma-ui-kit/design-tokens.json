      "size-36": { "$type": "fontSizes", "$value": "36" },
      "weight-regular": { "$type": "fontWeights", "$value": "400" },
      "weight-semibold": { "$type": "fontWeights", "$value": "600" },
      "weight-bold": { "$type": "fontWeights", "$value": "700" },
      "weight-extra": { "$type": "fontWeights", "$value": "800" },
      "line-height-tight": { "$type": "lineHeights", "$value": "1.2" },
      "line-height-normal": { "$type": "lineHeights", "$value": "1.6" }
    },
    "space": {
      "2": { "$type": "spacing", "$value": "2" },
      "4": { "$type": "spacing", "$value": "4" },
      "6": { "$type": "spacing", "$value": "6" },
      "8": { "$type": "spacing", "$value": "8" },
      "10": { "$type": "spacing", "$value": "10" },
      "12": { "$type": "spacing", "$value": "12" },
      "16": { "$type": "spacing", "$value": "16" },
      "20": { "$type": "spacing", "$value": "20" },
      "24": { "$type": "spacing", "$value": "24" },
      "32": { "$type": "spacing", "$value": "32" }
    },
    "radius": {
      "4": { "$type": "borderRadius", "$value": "4" },
      "6": { "$type": "borderRadius", "$value": "6" },
      "8": { "$type": "borderRadius", "$value": "8" },
      "999": { "$type": "borderRadius", "$value": "999" }
    }
  },
  "semantic": {
    "button": {
      "primary-bg": { "$type": "color", "$value": "{core.color.accent}" },
      "primary-text": { "$type": "color", "$value": "#ffffff" },
      "ghost-bg": { "$type": "color", "$value": "{core.color.surface-2}" },
      "ghost-text": { "$type": "color", "$value": "{core.color.muted-2}" },
      "danger-bg": { "$type": "color", "$value": "rgba(239,68,68,0.12)" },
      "danger-text": { "$type": "color", "$value": "{core.color.error}" }
    },
    "status": {
      "ok": { "$type": "color", "$value": "{core.color.green}" },
      "warn": { "$type": "color", "$value": "{core.color.warn}" },
      "error": { "$type": "color", "$value": "{core.color.error}" },
      "info": { "$type": "color", "$value": "{core.color.cyan}" }
    }
  }
