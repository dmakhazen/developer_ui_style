      "accent": { "$type": "color", "$value": "#3b82f6" },
      "cyan": { "$type": "color", "$value": "#22d3ee" },
      "green": { "$type": "color", "$value": "#22c55e" },
      "purple": { "$type": "color", "$value": "#a78bfa" },
      "warn": { "$type": "color", "$value": "#f59e0b" },
      "error": { "$type": "color", "$value": "#ef4444" }
    },
    "font": {
      "family-ui": { "$type": "fontFamilies", "$value": "Syne" },
      "family-mono": { "$type": "fontFamilies", "$value": "JetBrains Mono" },
      "size-10": { "$type": "fontSizes", "$value": "10" },
      "size-12": { "$type": "fontSizes", "$value": "12" },
      "size-14": { "$type": "fontSizes", "$value": "14" },
      "size-16": { "$type": "fontSizes", "$value": "16" },
